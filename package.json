{
  "name": "lazyeq",
  "version": "1.0.0",
  "type": "module",
  "description": "Sound tailored to your room — Sine sweep EQ analyzer for Bluetooth speakers",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:https": "vite --host",
    "signaling": "node server/signaling.js",
    "signaling:wss": "CERT=1 node server/signaling.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test tests/*.test.js",
    "test:dist": "node test.js",
    "build:test": "vite build && node --test tests/*.test.js && node test.js"
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "qrcode": "^1.5.4",
    "vite": "^6.0.0"
  }
}
